!.claude/settings.json
!.claude/skills/security-gate
.claude/settings.local.json

# Trellis primer system: INDEX.md and primer files are project-state (tracked)
!.claude/primers/
!.claude/primers/*
!.claude/commands/
.claude/commands/primer.md
.claude/commands/primer-refresh.md
.claude/commands/primer-check.md

# SE Core Codex parity (.agents and .codex are NOT under .claude/, just safety)
!.agents/
!.codex/
# --- SE Core inheritance symlinks (per-machine; regenerated by onboard-project.sh) ---
# Targets are absolute paths under $SE_CORE_ROOT, which differs on every developer's
# machine. Tracking these in git produces cross-machine merge conflicts. Each developer
# recreates them post-clone via:
#   ~/projects/se-core/scripts/onboard-project.sh <project-path>
# See se-core/engineering-process.md §4.2 + §10.5 for the full tracking policy.
.claude/rules/se-core.md
.claude/skills/process-gate
.agents/rules/se-core.md
.agents/skills/process-gate
# --- end SE Core fragment ---
.claude/rules/trellis.md
.claude/skills/security-gate
.agents/rules/trellis.md
.agents/skills/security-gate
# --- Trellis inheritance symlinks (7-skill set + presets) — per-machine; regenerated by onboard-project.sh ---
# Targets are absolute paths under $TRELLIS_ROOT, which differs on every developer's
# machine. Tracking these in git produces cross-machine merge conflicts. Each developer
# recreates them post-clone via:
#   ~/projects/trellis-instance/scripts/onboard-project.sh <project-path>
# See engineering-process.md (in the Trellis canonical repo) §4.2 + §10.5 for the full tracking policy.
.claude/rules/trellis.md
.claude/rules/preset-*.md
.claude/skills/process-gate
.claude/skills/security-gate
.claude/skills/clarify
.claude/skills/spec
.claude/skills/plan
.claude/skills/tasks
.claude/skills/analyze
.agents/rules/trellis.md
.agents/rules/preset-*.md
.agents/skills/process-gate
.agents/skills/security-gate
.agents/skills/clarify
.agents/skills/spec
.agents/skills/plan
.agents/skills/tasks
.agents/skills/analyze
# --- end Trellis fragment ---
