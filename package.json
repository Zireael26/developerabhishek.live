{
  "name": "akaushik-org",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "next dev --turbo",
    "prebuild": "tsx scripts/build-agent-skills-index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "process:check": "node scripts/process-gate.mjs",
    "stats:fetch": "node scripts/fetch-github-stats.mjs",
    "render:work": "node scripts/hyperframes/render-all.mjs",
    "render:posters": "node scripts/hyperframes/generate-posters.mjs",
    "analyze": "ANALYZE=true next build --webpack",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps",
    "ci:serve": "pnpm build && pnpm start"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.22.0",
    "tailwind-merge": "^2.5.4",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.50",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^22.7.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.169.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "postcss": "^8.5.10",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "tailwindcss": "4.3.0",
    "tsx": "^4.19.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  }
}
